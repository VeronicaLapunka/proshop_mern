# Backend environment variables
# Copy this file to .env and fill in with your actual values

# Node environment: development or production
NODE_ENV=development

# Backend server port
# On macOS, port 5000 is held by Control Center, so use 5001
PORT=5001

# MongoDB connection URI
# Local: mongodb://localhost:27017/proshop
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/proshop
MONGO_URI=mongodb://localhost:27017/proshop

# JWT secret for signing authentication tokens
# Use any long random string; changing it invalidates all active sessions
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random

# PayPal client ID for payment integration
# Use 'sandbox' for development testing
# Get a real client ID from https://developer.paypal.com for production
PAYPAL_CLIENT_ID=sandbox
